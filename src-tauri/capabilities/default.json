{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for OVO main window. Sidecar subprocess is spawned from Rust (no JS shell permissions needed). SQL permissions are reserved for Phase 3 chat persistence.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$APPDATA/attachments/**" },
        { "path": "$APPDATA/sql/**" },
        { "path": "$APPDATA/images/**" },
        { "path": "$APPLOCALDATA/attachments/**" },
        { "path": "$APPLOCALDATA/sql/**" },
        { "path": "$APPLOCALDATA/images/**" }
      ]
    },
    "fs:scope-app-recursive",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://**" },
        { "url": "http://localhost/**" },
        { "url": "http://localhost:**" },
        { "url": "http://127.0.0.1/**" },
        { "url": "http://127.0.0.1:**" }
      ]
    }
  ]
}
